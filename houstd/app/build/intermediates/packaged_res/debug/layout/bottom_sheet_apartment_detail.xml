<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bg_bottom_sheet">

    <ImageView android:layout_width="match_parent" android:layout_height="220dp"
        android:id="@+id/ivImage" android:scaleType="centerCrop" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <ImageButton android:id="@+id/btnClose" android:layout_width="32dp"
            android:layout_height="32dp" android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_close" android:padding="8dp"
            android:layout_gravity="end" android:layout_marginBottom="12dp" />

        <TextView android:id="@+id/tvTitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_location" android:layout_marginEnd="4dp"
                android:layout_gravity="center_vertical" />
            <TextView android:id="@+id/tvAddress" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_stat_indigo_light" android:padding="12dp"
                android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvPrice" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/indigo_900"
                    android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="per month" android:textColor="@color/text_hint" android:textSize="11sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_stat_purple_light" android:padding="12dp"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvBeds" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#6B21A8"
                    android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bedrooms" android:textColor="@color/text_hint" android:textSize="11sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_stat_amber_light" android:padding="12dp"
                android:layout_marginStart="4dp">
                <TextView android:id="@+id/tvRating" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#92400E"
                    android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rating" android:textColor="@color/text_hint" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/tvOwner" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Description" android:textColor="@color/text_primary"
            android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="6dp" />
        <TextView android:id="@+id/tvDescription" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="20dp" />

        <Button android:id="@+id/btnApply" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Apply for this Apartment"
            android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold"
            android:background="@drawable/bg_button_primary" />
    </LinearLayout>
</LinearLayout>
