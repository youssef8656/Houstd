<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="180dp">
            <ImageView
                android:id="@+id/ivApartmentImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_status_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Save button -->
            <ImageButton
                android:id="@+id/btnSave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="@drawable/bg_circle_white"
                android:src="@drawable/ic_heart_outline"
                android:padding="8dp"
                android:visibility="gone" />

            <!-- Price -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp"
                android:background="@drawable/bg_price_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/indigo_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:src="@drawable/ic_location" android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical" />
                <TextView android:id="@+id/tvAddress" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <!-- Beds + Rating -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:src="@drawable/ic_bed" android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical" />
                <TextView android:id="@+id/tvBeds" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:layout_marginEnd="16dp" />
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:src="@drawable/ic_star" android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical" />
                <TextView android:id="@+id/tvRating" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Student Actions -->
            <LinearLayout android:id="@+id/layoutStudentActions" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:visibility="gone">
                <Button android:id="@+id/btnDetails" android:layout_width="0dp"
                    android:layout_height="42dp" android:layout_weight="1" android:text="Details"
                    android:textSize="13sp" android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_secondary" android:textColor="@color/text_primary" />
                <Button android:id="@+id/btnApply" android:layout_width="0dp"
                    android:layout_height="42dp" android:layout_weight="1" android:text="Apply Now"
                    android:textSize="13sp" android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_primary" android:textColor="@color/white" />
            </LinearLayout>

            <!-- Admin Actions -->
            <LinearLayout android:id="@+id/layoutAdminActions" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:visibility="gone">
                <Button android:id="@+id/btnApprove" android:layout_width="0dp"
                    android:layout_height="42dp" android:layout_weight="1" android:text="Approve"
                    android:textSize="13sp" android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_approve" android:textColor="@color/white" />
                <Button android:id="@+id/btnReject" android:layout_width="0dp"
                    android:layout_height="42dp" android:layout_weight="1" android:text="Reject"
                    android:textSize="13sp" android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_reject" android:textColor="@color/white" />
            </LinearLayout>

            <!-- Owner Actions -->
            <LinearLayout android:id="@+id/layoutOwnerActions" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:visibility="gone">
                <Button android:id="@+id/btnDelete" android:layout_width="match_parent"
                    android:layout_height="42dp" android:text="Delete"
                    android:textSize="13sp"
                    android:background="@drawable/bg_button_delete" android:textColor="@color/red_600" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
