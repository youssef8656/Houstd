<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Houstd" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/indigo_600</item>
        <item name="colorPrimaryVariant">@color/indigo_900</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Houstd.Auth" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/indigo_600</item>
        <item name="android:statusBarColor">#1E1B4B</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="RoleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/selector_role_button</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
