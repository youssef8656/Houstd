<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_screen">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Profile Card (gradient) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_profile_gradient"
            android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:id="@+id/tvUserInitial" android:layout_width="60dp"
                android:layout_height="60dp" android:background="@drawable/bg_circle_semi"
                android:textColor="@color/white" android:textSize="24sp" android:textStyle="bold"
                android:gravity="center" android:layout_marginEnd="16dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center_vertical">
                <TextView android:id="@+id/tvUserName" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/white"
                    android:textSize="17sp" android:textStyle="bold" android:layout_marginBottom="3dp" />
                <TextView android:id="@+id/tvUserEmail" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#CCE0E0FF"
                    android:textSize="13sp" android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvUserRole" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:background="@drawable/bg_role_badge"
                    android:textColor="@color/white" android:textSize="11sp"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Menu Items -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="16dp" app:cardElevation="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Menu items -->
                <include layout="@layout/item_menu_row" android:id="@+id/rowProfile" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                <include layout="@layout/item_menu_row" android:id="@+id/rowFaq" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                <include layout="@layout/item_menu_row" android:id="@+id/rowSettings" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                <include layout="@layout/item_menu_row" android:id="@+id/rowFeedback" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Logout -->
        <Button android:id="@+id/btnLogout" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Sign Out"
            android:textColor="@color/red_600" android:textSize="15sp"
            android:background="@drawable/bg_button_logout" android:layout_marginBottom="16dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Houstd v1.0.0"
            android:textColor="@color/text_hint" android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>
</ScrollView>
