<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_student_home.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/white" android:padding="16dp"
        android:elevation="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Find Your Home 🏠"
            android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Search -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="16dp" android:background="@color/white">
        <EditText android:id="@+id/etSearch" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="@drawable/bg_search"
            android:hint="Search apartments..." android:textColorHint="@color/text_hint"
            android:textSize="14sp" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:inputType="text" android:imeOptions="actionSearch" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerApartments"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false" />
</LinearLayout>
